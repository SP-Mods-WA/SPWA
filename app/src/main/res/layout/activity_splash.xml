<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/sp_bg" android:gravity="center" android:orientation="vertical">
    <ImageView android:layout_width="100dp" android:layout_height="100dp"
        android:src="@mipmap/ic_launcher" android:layout_marginBottom="24dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_name" android:textSize="28sp" android:textStyle="bold"
        android:textColor="@color/sp_green"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Enhanced WhatsApp Experience" android:textSize="14sp"
        android:textColor="@color/sp_text2" android:layout_marginTop="8dp"/>
    <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="48dp" android:indeterminateTint="@color/sp_green"/>
</LinearLayout>

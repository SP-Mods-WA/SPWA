<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SPWhatsApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sp_dark_green</item>
        <item name="colorPrimaryVariant">@color/sp_dark_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/sp_green</item>
        <item name="android:statusBarColor">@color/sp_dark_green</item>
        <item name="android:navigationBarColor">@color/sp_bg</item>
        <item name="android:windowBackground">@color/sp_bg</item>
    </style>
    <style name="Theme.SPWhatsApp.Splash" parent="Theme.SPWhatsApp">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>
    <style name="PinButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="strokeColor">@color/sp_surface</item>
        <item name="rippleColor">@color/sp_green</item>
        <item name="backgroundTint">@color/sp_surface</item>
    </style>
</resources>

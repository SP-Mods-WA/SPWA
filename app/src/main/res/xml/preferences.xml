<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <SwitchPreference
        android:key="vpn_auto_start"
        android:title="Auto Start VPN"
        android:summary="App open වෙනකොටම VPN start"
        android:defaultValue="true"/>

    <EditTextPreference
        android:key="vpn_server"
        android:title="Server Address"
        android:defaultValue="10.0.0.1"/>

    <SwitchPreference
        android:key="vpn_boot_start"
        android:title="Start on Boot"
        android:defaultValue="true"/>

    <SwitchPreference
        android:key="vpn_kill_switch"
        android:title="Kill Switch"
        android:defaultValue="false"/>

    <ListPreference
        android:key="vpn_protocol"
        android:title="Protocol"
        android:entries="@array/vpn_protocols"
        android:entryValues="@array/vpn_protocol_values"
        android:defaultValue="udp"/>

</PreferenceScreen>
